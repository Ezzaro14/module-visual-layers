        <td><input name="layers[__INDEX__][marker_y]" data-layer-y class="admin__control-text" type="number" min="0" max="100" step="1" value="50"></td>
        <td><button type="button" class="action-delete" data-remove-row><?= $escaper->escapeHtml(__('Remove')) ?></button></td>
    </tr>
</template>

<script>
require(['domReady!'], function () {
    let rowIndex = <?= (int) $rowIndex ?>;
    const table = document.querySelector('#visual-layer-rows tbody');
    const template = document.querySelector('#visual-layer-row-template').innerHTML;
    const previewWrap = document.querySelector('#visual-layer-preview');
    const preview = document.querySelector('#visual-layer-image-preview');
    const markerPreview = document.querySelector('#visual-layer-marker-preview');
    const imageInput = document.querySelector('#image');
    let activeRow = table.querySelector('tr');
    let draggingRow = null;

    function clampPercent(value) {
        const numeric = Number.parseFloat(value);
        return Math.max(0, Math.min(100, Number.isFinite(numeric) ? numeric : 0));
    }

    function rowIndexValue(row) {
        return row ? row.getAttribute('data-layer-row') : '';
    }

    function markerLabel(row) {
        const label = row.querySelector('[data-layer-label]').value.trim();
        const sort = row.querySelector('[data-layer-sort]').value.trim();

        return label || sort || '?';
    }

    function nextSortOrder() {
        let maxSortOrder = 0;

        table.querySelectorAll('[data-layer-sort]').forEach(function (input) {
            const sortOrder = Number.parseInt(input.value, 10);
            maxSortOrder = Number.isFinite(sortOrder) ? Math.max(maxSortOrder, sortOrder) : maxSortOrder;
        });

        return maxSortOrder + 1;
    }

    function positionFromPointer(event) {
        const rect = preview.getBoundingClientRect();

        return {
            x: Math.round((event.clientX - rect.left) / rect.width * 100),
            y: Math.round((event.clientY - rect.top) / rect.height * 100)
        };
    }

    function setMarkerPosition(row, position) {
        row.querySelector('[data-layer-x]').value = clampPercent(position.x);
        row.querySelector('[data-layer-y]').value = clampPercent(position.y);
    }

    function moveRenderedMarker(row) {
        const marker = markerPreview.querySelector('[data-preview-row="' + rowIndexValue(row) + '"]');

        if (!marker) {
            return;
        }

        // Move the live marker directly so dragging stays visually continuous.
        marker.style.left = clampPercent(row.querySelector('[data-layer-x]').value) + '%';
        marker.style.top = clampPercent(row.querySelector('[data-layer-y]').value) + '%';
    }

    function renderMarkers() {
        markerPreview.innerHTML = '';

        table.querySelectorAll('tr').forEach(function (row) {
            const x = clampPercent(row.querySelector('[data-layer-x]').value);
            const y = clampPercent(row.querySelector('[data-layer-y]').value);
            const marker = document.createElement('button');

            marker.type = 'button';
            marker.className = 'visual-layer-admin-marker'
                + (row === activeRow ? ' is-active' : '');
            marker.style.left = x + '%';
            marker.style.top = y + '%';
            marker.textContent = markerLabel(row);
            marker.setAttribute('data-preview-row', rowIndexValue(row));

            markerPreview.appendChild(marker);
        });
    }

    // Percent coordinates bind markers to the rendered image box during responsive scaling.
    document.querySelector('#add-visual-layer-row').addEventListener('click', function () {
        const sortOrder = nextSortOrder();

        table.insertAdjacentHTML('beforeend', template.replace(/__INDEX__/g, String(rowIndex++)));
        activeRow = table.querySelector('tr:last-child');
        activeRow.querySelector('[data-layer-sort]').value = sortOrder;
        activeRow.querySelector('[data-layer-label]').value = sortOrder;
        renderMarkers();
    });

    table.addEventListener('focusin', function (event) {
        activeRow = event.target.closest('tr') || activeRow;
        renderMarkers();
    });

    table.addEventListener('input', function () {
        renderMarkers();
    });

    table.addEventListener('click', function (event) {
        if (event.target.matches('[data-remove-row]')) {
            event.target.closest('tr').remove();
            activeRow = table.querySelector('tr');
            renderMarkers();
        }
    });

    markerPreview.addEventListener('click', function (event) {
        const marker = event.target.closest('[data-preview-row]');
        if (!marker) {
            return;
        }

        activeRow = table.querySelector('[data-layer-row="' + marker.getAttribute('data-preview-row') + '"]') || activeRow;
        renderMarkers();
    });

    markerPreview.addEventListener('pointerdown', function (event) {
        const marker = event.target.closest('[data-preview-row]');

        if (!marker) {
            return;
        }

        event.preventDefault();
        activeRow = table.querySelector('[data-layer-row="' + marker.getAttribute('data-preview-row') + '"]') || activeRow;
        draggingRow = activeRow;
        markerPreview.querySelectorAll('.visual-layer-admin-marker').forEach(function (renderedMarker) {
            renderedMarker.classList.toggle('is-active', renderedMarker === marker);
            renderedMarker.classList.remove('is-dragging');
        });
        marker.classList.add('is-dragging');
    });

    document.addEventListener('pointermove', function (event) {
        if (!draggingRow) {
            return;
        }

        event.preventDefault();
        setMarkerPosition(draggingRow, positionFromPointer(event));
        moveRenderedMarker(draggingRow);
    });

    document.addEventListener('pointerup', function () {
        if (!draggingRow) {
            return;
        }

        draggingRow = null;
        renderMarkers();
    });

    document.addEventListener('pointercancel', function () {
        if (!draggingRow) {
            return;
        }

        draggingRow = null;
        renderMarkers();
    });

    previewWrap.addEventListener('click', function (event) {
        if (event.target.closest('[data-preview-row]')) {
            return;
        }

        if (!activeRow) {
            return;
        }

        setMarkerPosition(activeRow, positionFromPointer(event));
        renderMarkers();
    });

    imageInput.addEventListener('change', function () {
        const file = imageInput.files && imageInput.files[0];
        if (!file) {
            return;
        }

        preview.src = URL.createObjectURL(file);
        preview.style.display = 'block';
        renderMarkers();
    });

    renderMarkers();
});
</script>
