<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="ezzar_visual_layer_visual" resource="default" engine="innodb" comment="Visual Layer">
        <column xsi:type="int" name="visual_id" unsigned="true" nullable="false" identity="true" comment="Visual ID"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Title"/>
        <column xsi:type="varchar" name="frontend_title" nullable="true" length="255" comment="Frontend Title"/>
        <column xsi:type="varchar" name="image" nullable="true" length="255" comment="Image Path"/>
        <column xsi:type="varchar" name="image_alt" nullable="true" length="255" comment="Image Alt Text"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="visual_id"/>
        </constraint>
        <index referenceId="EZZAR_VISUAL_LAYER_VISUAL_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>

    <table name="ezzar_visual_layer" resource="default" engine="innodb" comment="Visual Layer">
        <column xsi:type="int" name="layer_id" unsigned="true" nullable="false" identity="true" comment="Layer ID"/>
        <column xsi:type="int" name="visual_id" unsigned="true" nullable="false" comment="Visual ID"/>
        <column xsi:type="int" name="sort_order" nullable="false" default="1" comment="Sort Order"/>
        <column xsi:type="varchar" name="marker_label" nullable="false" length="32" comment="Marker Label"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Title"/>
        <column xsi:type="text" name="what_it_is" nullable="true" comment="What It Is"/>
        <column xsi:type="text" name="what_it_does" nullable="true" comment="What It Does"/>
        <column xsi:type="decimal" name="marker_x" scale="2" precision="5" nullable="false" default="50.00" comment="Marker X Percent"/>
        <column xsi:type="decimal" name="marker_y" scale="2" precision="5" nullable="false" default="50.00" comment="Marker Y Percent"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="layer_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="EZZAR_VISUAL_LAYER_VISUAL_ID_EZZAR_VISUAL_LAYER_VISUAL_VISUAL_ID"
                    table="ezzar_visual_layer" column="visual_id"
                    referenceTable="ezzar_visual_layer_visual" referenceColumn="visual_id"
                    onDelete="CASCADE"/>
        <index referenceId="EZZAR_VISUAL_LAYER_VISUAL_ID_SORT_ORDER" indexType="btree">
            <column name="visual_id"/>
            <column name="sort_order"/>
        </index>
    </table>
</schema>
